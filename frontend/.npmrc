# Next.js 15.0.0 shipped with a peer-dep range that only accepted React 18.2+
# or a single React 19 RC snapshot (`19.0.0-rc-65a56d0e-20241020`). This repo
# uses React 19.0.0 stable, which npm >=10 strict resolution then rejects.
#
# React 19.0.0 stable is API-compatible with the RC Next 15.0.0 was tested
# against, so `legacy-peer-deps` is the safe, industry-standard workaround
# and is what most Next 15 + React 19 projects use until they bump to
# next@15.0.3+ (which widened the peer-dep range).
#
# This file applies to both CI (`npm ci` in Docker) and local dev
# (`npm install` on a workstation), so behaviour stays consistent.
legacy-peer-deps=true
